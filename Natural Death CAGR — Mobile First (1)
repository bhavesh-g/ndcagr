<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Natural Death CAGR — Mobile First</title>
<meta name="description" content="A cinematic term insurance calculator that reframes insurance through implied CAGR and mortality mathematics.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300..700&family=Geist+Mono:wght@300..700&display=swap" rel="stylesheet">
<style>
:root {
  --text-xs: clamp(0.75rem, 0.72rem + 0.2vw, 0.875rem);
  --text-sm: clamp(0.875rem, 0.84rem + 0.25vw, 1rem);
  --text-base: clamp(1rem, 0.96rem + 0.2vw, 1.0625rem);
  --text-lg: clamp(1.125rem, 1.02rem + 0.55vw, 1.35rem);
  --text-xl: clamp(1.5rem, 1.15rem + 1.5vw, 2.2rem);
  --text-2xl: clamp(2rem, 1.2rem + 3vw, 3.3rem);
  --text-3xl: clamp(2.4rem, 1.1rem + 5vw, 4.8rem);
  --text-hero: clamp(2.85rem, 1.15rem + 8vw, 7rem);

  --space-1: 0.25rem;
  --space-2: 0.5rem;
  --space-3: 0.75rem;
  --space-4: 1rem;
  --space-5: 1.25rem;
  --space-6: 1.5rem;
  --space-8: 2rem;
  --space-10: 2.5rem;
  --space-12: 3rem;
  --space-16: 4rem;
  --space-20: 5rem;
  --space-24: 6rem;
  --space-32: 8rem;

  --color-bg: #09090b;
  --color-surface: #0f1013;
  --color-surface-2: #15161a;
  --color-surface-3: #1b1c21;
  --color-border: rgba(255,255,255,0.07);
  --color-border-strong: rgba(255,255,255,0.12);
  --color-divider: rgba(255,255,255,0.05);
  --color-text: #ececef;
  --color-text-muted: #a0a1aa;
  --color-text-faint: #5d5f69;
  --color-accent: #8d3042;
  --color-accent-bright: #c94a67;
  --color-accent-soft: rgba(201,74,103,0.14);

  --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-mono: 'Geist Mono', 'SFMono-Regular', Consolas, monospace;

  --radius-sm: 0.5rem;
  --radius-md: 0.75rem;
  --radius-lg: 1rem;
  --radius-xl: 1.25rem;
  --shadow-soft: 0 12px 40px rgba(0,0,0,0.28);
  --transition: 220ms cubic-bezier(0.16, 1, 0.3, 1);

  --content-default: 1040px;
  --content-narrow: 720px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  -webkit-text-size-adjust: 100%;
  text-size-adjust: 100%;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
  scroll-padding-top: 5rem;
}
body {
  min-height: 100dvh;
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.65;
  color: var(--color-text);
  background:
    radial-gradient(circle at 50% 25%, rgba(141,48,66,0.09), transparent 34%),
    radial-gradient(circle at 20% 80%, rgba(141,48,66,0.05), transparent 28%),
    var(--color-bg);
  overflow-x: hidden;
}
body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.95' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px 180px;
}
img, svg, canvas { display: block; max-width: 100%; }
button, input, select { font: inherit; color: inherit; }
button { border: 0; background: none; cursor: pointer; }
a { color: inherit; text-decoration: none; }
h1, h2, h3 { line-height: 1.06; text-wrap: balance; }
p { text-wrap: pretty; }
::selection { background: rgba(201,74,103,0.28); color: var(--color-text); }
:focus-visible {
  outline: 2px solid var(--color-accent-bright);
  outline-offset: 3px;
  border-radius: 0.4rem;
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

.mono { font-family: var(--font-mono); }
.container, .container-narrow {
  width: min(100%, var(--content-default));
  margin-inline: auto;
  padding-inline: var(--space-4);
  position: relative;
  z-index: 1;
}
.container-narrow { width: min(100%, var(--content-narrow)); }
.section-pad { padding-block: clamp(var(--space-16), 9vw, var(--space-24)); }
.kicker {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-accent-bright);
  margin-bottom: var(--space-3);
}
.section-title {
  font-size: var(--text-2xl);
  font-weight: 320;
  letter-spacing: -0.03em;
  margin-bottom: var(--space-4);
}
.section-copy {
  color: var(--color-text-muted);
  max-width: 44ch;
}
.card {
  background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0));
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-soft);
}
.reveal {
  opacity: 0;
  filter: blur(6px);
  transform: translateY(8px);
  transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), filter 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1);
}
.reveal.visible {
  opacity: 1;
  filter: blur(0);
  transform: translateY(0);
}
.reveal.delay-1 { transition-delay: 0.12s; }
.reveal.delay-2 { transition-delay: 0.24s; }
.reveal.delay-3 { transition-delay: 0.36s; }

nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: max(var(--space-3), env(safe-area-inset-top)) var(--space-4) var(--space-3);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
  transition: background var(--transition), border-color var(--transition), backdrop-filter var(--transition);
  border-bottom: 1px solid transparent;
}
nav.scrolled {
  background: rgba(9,9,11,0.78);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom-color: var(--color-border);
}
.nav-inner {
  width: min(100%, var(--content-default));
  margin-inline: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}
.brand {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}
.brand-mark {
  width: 1.15rem;
  height: 1.15rem;
  border: 1px solid var(--color-accent);
  border-radius: 0.25rem;
  display: grid;
  place-items: center;
  color: var(--color-accent-bright);
}
.nav-tag {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  color: var(--color-text-faint);
  text-transform: uppercase;
  text-align: right;
}

.hero {
  min-height: 100svh;
  display: grid;
  place-items: center;
  padding: calc(var(--space-20) + env(safe-area-inset-top)) var(--space-4) var(--space-12);
  text-align: center;
}
.hero-inner { width: min(100%, 860px); }
.hero h1 {
  font-size: var(--text-hero);
  font-weight: 290;
  letter-spacing: -0.05em;
  max-width: 10ch;
  margin-inline: auto;
}
.hero h1 .muted { color: var(--color-text-muted); }
.hero-sub {
  margin: var(--space-6) auto 0;
  max-width: 33ch;
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}
.scroll-cue {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-10);
  color: var(--color-text-faint);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.scroll-cue-line {
  width: 1px;
  height: 2.9rem;
  background: linear-gradient(to bottom, rgba(201,74,103,0.8), transparent);
  animation: cue 2.4s ease-in-out infinite;
}
@keyframes cue {
  0% { opacity: 0; transform: scaleY(0.2); transform-origin: top; }
  35% { opacity: 0.75; }
  100% { opacity: 0; transform: scaleY(1); transform-origin: bottom; }
}

.split-grid {
  display: grid;
  gap: var(--space-3);
}
.split-card {
  padding: var(--space-8) var(--space-6);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
}
.split-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin-bottom: var(--space-3);
}
.split-card p {
  font-size: var(--text-lg);
  font-weight: 300;
  color: var(--color-text-muted);
}
.split-card strong {
  color: var(--color-text);
  font-weight: 430;
}
.center-thought {
  margin-top: var(--space-10);
  text-align: center;
  max-width: 58ch;
  margin-inline: auto;
  color: var(--color-text-muted);
}
.center-thought p + p { margin-top: var(--space-5); }

.calc-wrap {
  margin-top: var(--space-10);
}
.form-card { padding: var(--space-6) var(--space-5); }
.form-grid {
  display: grid;
  gap: var(--space-5);
}
.field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}
.field label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
}
.input-shell {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-height: 3.25rem;
  border-bottom: 1px solid var(--color-border);
  transition: border-color var(--transition), box-shadow var(--transition);
}
.input-shell:focus-within {
  border-color: var(--color-accent-bright);
  box-shadow: inset 0 -1px 0 var(--color-accent-bright);
}
.input-shell span.prefix,
.input-shell span.suffix {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--color-text-faint);
  flex-shrink: 0;
}
input.form-input,
select.form-select {
  width: 100%;
  min-width: 0;
  border: 0;
  outline: none;
  background: transparent;
}
input.form-input {
  font-size: 16px;
  padding-block: var(--space-3);
  font-family: var(--font-mono);
  font-weight: 320;
  color: var(--color-text);
  -moz-appearance: textfield;
}
input.form-input::-webkit-outer-spin-button,
input.form-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
input.form-input::placeholder { color: var(--color-text-faint); }
select.form-select {
  appearance: none;
  -webkit-appearance: none;
  flex: 0 0 auto;
  width: auto;
  min-width: 5.25rem;
  padding: var(--space-2) var(--space-3);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  background: var(--color-surface-2);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.field-hint {
  font-size: var(--text-xs);
  color: var(--color-text-faint);
}
.cta {
  width: 100%;
  margin-top: var(--space-2);
  min-height: 3.3rem;
  border-radius: var(--radius-lg);
  background: linear-gradient(180deg, rgba(201,74,103,0.11), rgba(201,74,103,0.04));
  border: 1px solid rgba(201,74,103,0.2);
  color: var(--color-text);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  transition: transform var(--transition), border-color var(--transition), background var(--transition);
}
.cta:hover { border-color: rgba(201,74,103,0.35); }
.cta:active { transform: scale(0.992); }

.result {
  margin-top: var(--space-8);
  display: none;
}
.result.visible { display: block; }
.result-card {
  padding: var(--space-8) var(--space-5);
  text-align: center;
}
.result-primary {
  font-size: var(--text-xl);
  font-weight: 300;
  letter-spacing: -0.02em;
  line-height: 1.35;
}
.result-number {
  display: block;
  margin: var(--space-5) 0;
  font-family: var(--font-mono);
  font-size: clamp(2.5rem, 10vw, 4.2rem);
  color: var(--color-accent-bright);
  letter-spacing: -0.05em;
}
.result-secondary {
  padding-top: var(--space-5);
  margin-top: var(--space-5);
  border-top: 1px solid var(--color-divider);
  color: var(--color-text-muted);
  font-size: var(--text-sm);
}
.meta-grid {
  margin-top: var(--space-6);
  display: grid;
  gap: var(--space-2);
}
.meta-box {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-4);
}
.meta-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin-bottom: var(--space-2);
}
.meta-value {
  font-family: var(--font-mono);
  color: var(--color-text-muted);
}

.graph-card { padding: var(--space-6) var(--space-4) var(--space-4); }
.chart-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 5;
}
.graph-caption {
  margin-top: var(--space-4);
  color: var(--color-text-faint);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.graph-notes {
  margin-top: var(--space-4);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-divider);
  display: grid;
  gap: var(--space-3);
}
.graph-note {
  font-family: var(--font-mono);
  font-size: 0.74rem;
  color: var(--color-text-faint);
}
.graph-note strong {
  display: block;
  color: var(--color-text-muted);
  font-weight: 400;
}

.edu-grid {
  display: grid;
  gap: var(--space-3);
  margin-top: var(--space-8);
}
.edu-card {
  padding: var(--space-6);
  border-radius: var(--radius-lg);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
}
.edu-card h3 {
  font-size: var(--text-lg);
  font-weight: 360;
  margin-bottom: var(--space-3);
  letter-spacing: -0.02em;
}
.edu-card p,
.edu-card li {
  color: var(--color-text-muted);
}
.edu-card ul {
  list-style: none;
  display: grid;
  gap: var(--space-2);
}
.edu-card li {
  padding-left: var(--space-4);
  position: relative;
}
.edu-card li::before {
  content: "—";
  position: absolute;
  left: 0;
  color: var(--color-accent-bright);
}
.closing-quote {
  font-size: var(--text-2xl);
  font-weight: 300;
  letter-spacing: -0.03em;
  line-height: 1.25;
  max-width: 12ch;
  margin-inline: auto;
  text-align: center;
}
.closing-copy {
  margin: var(--space-6) auto 0;
  max-width: 42ch;
  text-align: center;
  color: var(--color-text-muted);
}
.footer {
  padding: var(--space-6) var(--space-4) calc(var(--space-6) + env(safe-area-inset-bottom));
  border-top: 1px solid var(--color-divider);
}
.footer-inner {
  width: min(100%, var(--content-default));
  margin-inline: auto;
  display: grid;
  gap: var(--space-2);
  text-align: center;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--color-text-faint);
  letter-spacing: 0.08em;
}

@media (min-width: 720px) {
  .container, .container-narrow { padding-inline: var(--space-6); }
  .hero { padding-bottom: var(--space-20); }
  .hero-sub { font-size: var(--text-base); max-width: 44ch; }
  .split-grid { grid-template-columns: 1fr 1fr; }
  .form-grid { grid-template-columns: 1fr 1fr; gap: var(--space-6) var(--space-8); }
  .field.full { grid-column: 1 / -1; }
  .meta-grid { grid-template-columns: repeat(3, 1fr); }
  .graph-card { padding: var(--space-8) var(--space-6) var(--space-5); }
  .chart-wrap { aspect-ratio: 16 / 8; }
  .graph-notes { grid-template-columns: repeat(3, 1fr); }
  .edu-grid { grid-template-columns: repeat(3, 1fr); }
  .footer-inner { grid-template-columns: 1fr 1fr; text-align: left; }
  .footer-inner span:last-child { text-align: right; }
}

@media (min-width: 960px) {
  .hero h1 { max-width: 12ch; }
  .form-card { padding: var(--space-8); }
  .result-card { padding: var(--space-10) var(--space-8); }
}
</style>
</head>
<body>
<nav id="nav" aria-label="Primary navigation">
  <div class="nav-inner">
    <a class="brand" href="#hero" aria-label="Natural Death CAGR home">
      <span class="brand-mark" aria-hidden="true">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.3">
          <polyline points="1,8 4,3 6,5 9,1"></polyline>
        </svg>
      </span>
      NDCAGR
    </a>
    <div class="nav-tag">mortality mathematics</div>
  </div>
</nav>

<header class="hero" id="hero">
  <div class="hero-inner">
    <p class="kicker reveal visible">A financial thought experiment</p>
    <h1 class="reveal visible">
      What CAGR do you expect from your <span class="muted">natural death?</span>
    </h1>
    <p class="hero-sub reveal visible">
      Term insurance is the only product where extraordinary returns require unfortunate timing.
    </p>
    <div class="scroll-cue reveal visible" aria-hidden="true">
      <span>scroll</span>
      <div class="scroll-cue-line"></div>
    </div>
  </div>
</header>

<section class="section-pad" id="paradox">
  <div class="container">
    <div class="split-grid reveal">
      <article class="split-card">
        <div class="split-label">Investment</div>
        <p><strong>Rewards survival.</strong> The longer you remain around, the longer compounding has room to work.</p>
      </article>
      <article class="split-card">
        <div class="split-label">Term insurance</div>
        <p><strong>Rewards interruption.</strong> The earlier the payout occurs, the more mathematically attractive the return appears.</p>
      </article>
    </div>
    <div class="center-thought reveal delay-1">
      <p>Every additional year lived adds another premium while the payout remains fixed. The ratio gets less flattering. The life gets better.</p>
      <p>Longevity is wonderful. Financially inefficient, but wonderful.</p>
    </div>
  </div>
</section>

<section class="section-pad" id="calculator">
  <div class="container-narrow">
    <div class="reveal">
      <p class="kicker">The instrument</p>
      <h2 class="section-title">Implied CAGR Calculator</h2>
      <p class="section-copy">Use normal insurance language. Enter cover in lakh or crore. Let the page do the zeros.</p>
    </div>

    <div class="calc-wrap">
      <form class="form-card card reveal delay-2" id="calc-form" novalidate>
        <div class="form-grid">
          <div class="field">
            <label for="premium">Annual premium</label>
            <div class="input-shell">
              <span class="prefix">₹</span>
              <input class="form-input" id="premium" type="number" inputmode="numeric" min="1" step="1" placeholder="12000" required>
            </div>
            <div class="field-hint">Yearly amount paid to the insurer.</div>
          </div>

          <div class="field">
            <label for="cover-amount">Cover amount</label>
            <div class="input-shell">
              <span class="prefix">₹</span>
              <input class="form-input" id="cover-amount" type="number" inputmode="decimal" min="0.1" step="0.1" placeholder="1" required>
              <select class="form-select" id="cover-unit" aria-label="Cover unit">
                <option value="100000">Lakh</option>
                <option value="10000000" selected>Crore</option>
              </select>
            </div>
            <div class="field-hint">Example: 1 crore, 50 lakh, 2.5 crore.</div>
          </div>

          <div class="field">
            <label for="current-age">Current age</label>
            <div class="input-shell">
              <input class="form-input" id="current-age" type="number" inputmode="numeric" min="18" max="90" placeholder="30" required>
              <span class="suffix">yrs</span>
            </div>
            <div class="field-hint">Your age today.</div>
          </div>

          <div class="field">
            <label for="expiry-age">Policy expiry age</label>
            <div class="input-shell">
              <input class="form-input" id="expiry-age" type="number" inputmode="numeric" min="19" max="100" placeholder="65" required>
              <span class="suffix">yrs</span>
            </div>
            <div class="field-hint">Age when term coverage ends.</div>
          </div>

          <div class="field" id="desired-cagr-field">
            <label for="desired-cagr">Desired CAGR</label>
            <div class="input-shell">
              <input class="form-input" id="desired-cagr" type="number" inputmode="decimal" min="0.1" max="200" step="0.1" placeholder="12">
              <span class="suffix">%</span>
            </div>
            <div class="field-hint">What annualized return are you implicitly asking for?</div>
          </div>
        </div>

        <button class="cta" id="calculate-btn" type="submit">Solve for the age</button>
      </form>

      <div class="result" id="result" aria-live="polite" aria-atomic="true">
        <div class="result-card card">
          <div class="result-primary" id="result-primary">—</div>
          <span class="result-number mono" id="result-number">—</span>
          <div class="result-secondary" id="result-secondary">—</div>
          <div class="meta-grid" id="meta-grid"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-pad" id="curve">
  <div class="container-narrow">
    <div class="reveal">
      <p class="kicker">The curve</p>
      <h2 class="section-title">Survival vs. return</h2>
      <p class="section-copy">This line slopes downward for structural reasons. More life means more premiums. More premiums mean lower implied CAGR.</p>
    </div>
    <div class="graph-card card reveal delay-1">
      <div class="chart-wrap">
        <canvas id="chart" role="img" aria-label="Chart showing implied CAGR declining as age of death increases."></canvas>
      </div>
      <div class="graph-caption">implied annualized CAGR by age of death</div>
      <div class="graph-notes">
        <div class="graph-note"><strong>Earlier death</strong> Higher CAGR.</div>
        <div class="graph-note"><strong>Longer survival</strong> Lower CAGR.</div>
        <div class="graph-note"><strong>The point</strong> Insurance is a hedge, not an asset class.</div>
      </div>
    </div>
  </div>
</section>

<section class="section-pad" id="education">
  <div class="container">
    <div class="reveal">
      <p class="kicker">A better interpretation</p>
      <h2 class="section-title">Term insurance is an expense worth expensing on</h2>
      <p class="section-copy">The right mental model is not “What return did I get?” The right question is “What financial damage did I prevent for people who depend on me?”</p>
    </div>

    <div class="edu-grid">
      <article class="edu-card reveal delay-1">
        <h3>Not all money spent needs to compound</h3>
        <p>Rent, antivirus, backups, legal compliance, and fire extinguishers are all deliberate expenses. Their value is highest when the catastrophe never arrives.</p>
      </article>

      <article class="edu-card reveal delay-2">
        <h3>What you are actually buying</h3>
        <ul>
          <li>Income continuity for dependents.</li>
          <li>Debt protection during vulnerable years.</li>
          <li>Time for your family to reorganize after interruption.</li>
        </ul>
      </article>

      <article class="edu-card reveal delay-3">
        <h3>The category error</h3>
        <p>If the best personal outcome is that the product never pays out, then it should not be evaluated like equity, real estate, or a fixed-income instrument.</p>
      </article>
    </div>
  </div>
</section>

<section class="section-pad" id="closing">
  <div class="container-narrow">
    <blockquote class="closing-quote reveal">Buy term insurance to protect continuity. Not to optimize mortality.</blockquote>
    <p class="closing-copy reveal delay-1">The payout is not the aspiration. The peace of mind is. If the policy expires unused, the financial return was poor and the human outcome was excellent.</p>
  </div>
</section>

<footer class="footer">
  <div class="footer-inner">
    <span>Natural Death CAGR · 2026</span>
    <span>FV = P × [((1+r)^n − 1) / r]</span>
  </div>
</footer>

<script>
let graphPoints = [];

const form = document.getElementById('calc-form');
const result = document.getElementById('result');
const resultPrimary = document.getElementById('result-primary');
const resultNumber = document.getElementById('result-number');
const resultSecondary = document.getElementById('result-secondary');
const metaGrid = document.getElementById('meta-grid');
const nav = document.getElementById('nav');

window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 24);
}, { passive: true });

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.reveal:not(.visible)').forEach(el => observer.observe(el));

function formatINR(n) {
  return new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 }).format(n);
}

function fvAnnuity(premium, r, n) {
  if (Math.abs(r) < 1e-8) return premium * n;
  return premium * ((Math.pow(1 + r, n) - 1) / r);
}

function impliedCAGR(premium, cover, years) {
  if (years <= 0) return null;
  if (years <= 1) {
    if (cover <= premium) return 0;
    return 9;
  }
  let lo = 0.000001;
  let hi = 10;
  const lowFV = fvAnnuity(premium, lo, years);
  const highFV = fvAnnuity(premium, hi, years);
  if (cover <= lowFV) return 0;
  if (cover >= highFV) return Infinity;
  for (let i = 0; i < 90; i++) {
    const mid = (lo + hi) / 2;
    const midFV = fvAnnuity(premium, mid, years);
    if (midFV < cover) lo = mid; else hi = mid;
  }
  return (lo + hi) / 2;
}

function showResult(primary, number, secondary, metaItems) {
  resultPrimary.textContent = primary;
  resultNumber.textContent = number;
  resultSecondary.textContent = secondary;
  metaGrid.innerHTML = metaItems.map(item => `
    <div class="meta-box">
      <div class="meta-label">${item.label}</div>
      <div class="meta-value">${item.value}</div>
    </div>
  `).join('');
  result.classList.add('visible');
  setTimeout(() => result.scrollIntoView({ behavior: 'smooth', block: 'center' }), 120);
}

function shake(el) {
  el.animate([
    { transform: 'translateX(0)' },
    { transform: 'translateX(-4px)' },
    { transform: 'translateX(4px)' },
    { transform: 'translateX(-3px)' },
    { transform: 'translateX(0)' }
  ], { duration: 320, easing: 'ease' });
}

function requiredDeathAge(premium, cover, currentAge, expiryAge, targetPct) {
  // Returns { status, age, cagrAtExpiry }
  // status: 'achieved_before_expiry' | 'never_within_term' | 'already_beaten_at_expiry'
  const target = targetPct / 100;
  const cagrAtExpiry = impliedCAGR(premium, cover, expiryAge - currentAge);

  const cagrAt1yr = impliedCAGR(premium, cover, 1);
  if (isFinite(cagrAt1yr) && cagrAt1yr < target) {
    return { status: 'never_within_term', age: null, cagrAtExpiry };
  }

  if (isFinite(cagrAtExpiry) && cagrAtExpiry >= target) {
    return { status: 'already_beaten_at_expiry', age: expiryAge, cagrAtExpiry };
  }

  for (let age = Math.ceil(currentAge + 1); age <= expiryAge; age++) {
    const cagr = impliedCAGR(premium, cover, age - currentAge);
    if (cagr !== null && isFinite(cagr) && cagr <= target) {
      return { status: 'achieved_before_expiry', age, cagrAtExpiry };
    }
  }
  return { status: 'never_within_term', age: null, cagrAtExpiry };
}

form.addEventListener('submit', (e) => {
  e.preventDefault();
  const premium = parseFloat(document.getElementById('premium').value);
  const coverAmount = parseFloat(document.getElementById('cover-amount').value);
  const coverUnit = parseFloat(document.getElementById('cover-unit').value);
  const cover = coverAmount * coverUnit;
  const currentAge = parseFloat(document.getElementById('current-age').value);
  const expiryAge = parseFloat(document.getElementById('expiry-age').value);

  if (!premium || !coverAmount || !currentAge || !expiryAge || expiryAge <= currentAge) {
    shake(form);
    return;
  }

  const desired = parseFloat(document.getElementById('desired-cagr').value);
  if (!desired || desired <= 0) { shake(form); return; }

  const resultObj = requiredDeathAge(premium, cover, currentAge, expiryAge, desired);
  const { status, age, cagrAtExpiry } = resultObj;
  const cagrAtExpiryPct = isFinite(cagrAtExpiry) ? (cagrAtExpiry * 100).toFixed(2) : '0.00';

  if (status === 'never_within_term') {
    showResult(
      `A CAGR of ${desired}% cannot be achieved within this policy — even in year one.`,
      'Unachievable',
      `Your desired return exceeds what this policy can ever deliver, regardless of timing. The cover amount (₹${formatINR(cover)}) is structurally insufficient relative to the annual premium (₹${formatINR(premium)}) to generate ${desired}% annualized. Consider this a reminder: insurance is priced for protection, not return.`,
      [
        { label: 'Desired CAGR', value: `${desired}%` },
        { label: 'Max possible', value: `~${(impliedCAGR(premium, cover, 1) * 100).toFixed(1)}% (yr 1)` },
        { label: 'CAGR at expiry', value: `${cagrAtExpiryPct}%` }
      ]
    );
  } else if (status === 'already_beaten_at_expiry') {
    showResult(
      `Good news, mathematically speaking: even if you live until the policy expires at age ${expiryAge}, you still achieve`,
      `${cagrAtExpiryPct}% CAGR`,
      `This policy has a cover-to-premium ratio high enough that even full survival returns ${cagrAtExpiryPct}% annualized — above your desired ${desired}%. You don't need to die early to hit this number. Which is unusually pleasant to say in this context.`,
      [
        { label: 'CAGR at expiry', value: `${cagrAtExpiryPct}%` },
        { label: 'Your desired', value: `${desired}%` },
        { label: 'Total premiums', value: `₹${formatINR(premium * (expiryAge - currentAge))}` }
      ]
    );
  } else {
    const years = age - currentAge;
    showResult(
      `To achieve ${desired}% annualized returns, the payout would need to occur before age`,
      String(age),
      `After age ${age}, the accumulating premiums drag CAGR below your threshold. If you survive to policy expiry, the implied return settles at ${cagrAtExpiryPct}%. Which is why term insurance should not be evaluated as a return-generating product — the best personal outcome remains the worst financial one.`,
      [
        { label: 'Required by age', value: String(age) },
        { label: 'CAGR at expiry', value: `${cagrAtExpiryPct}%` },
        { label: 'Premiums if full term', value: `₹${formatINR(premium * (expiryAge - currentAge))}` }
      ]
    );
  }

  buildGraphData(premium, cover, currentAge, expiryAge);
  drawChart();
});

function buildGraphData(premium, cover, currentAge, expiryAge) {
  graphPoints = [];
  for (let age = Math.ceil(currentAge + 1); age <= expiryAge; age++) {
    const rate = impliedCAGR(premium, cover, age - currentAge);
    if (rate !== null && isFinite(rate) && rate >= 0 && rate < 4) {
      graphPoints.push({ age, pct: rate * 100 });
    }
  }
}

function drawChart() {
  const canvas = document.getElementById('chart');
  const ctx = canvas.getContext('2d');
  const box = canvas.parentElement;
  const width = box.clientWidth;
  const height = box.clientHeight;
  const dpr = window.devicePixelRatio || 1;
  canvas.width = width * dpr;
  canvas.height = height * dpr;
  canvas.style.width = width + 'px';
  canvas.style.height = height + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  ctx.clearRect(0, 0, width, height);

  if (!graphPoints.length) return;

  const pad = { top: 18, right: 16, bottom: 38, left: 46 };
  const innerW = width - pad.left - pad.right;
  const innerH = height - pad.top - pad.bottom;
  const ages = graphPoints.map(p => p.age);
  const vals = graphPoints.map(p => p.pct);
  const minAge = Math.min(...ages);
  const maxAge = Math.max(...ages);
  const minVal = 0;
  const maxVal = Math.max(...vals) * 1.05;
  const x = v => pad.left + ((v - minAge) / Math.max(1, maxAge - minAge)) * innerW;
  const y = v => pad.top + (1 - (v - minVal) / Math.max(0.0001, maxVal - minVal)) * innerH;

  for (let i = 0; i <= 4; i++) {
    const gy = pad.top + (i / 4) * innerH;
    ctx.beginPath();
    ctx.moveTo(pad.left, gy);
    ctx.lineTo(width - pad.right, gy);
    ctx.strokeStyle = 'rgba(255,255,255,0.045)';
    ctx.lineWidth = 1;
    ctx.stroke();

    const label = (maxVal - (i / 4) * (maxVal - minVal)).toFixed(1) + '%';
    ctx.fillStyle = 'rgba(160,161,170,0.72)';
    ctx.font = '11px Geist Mono';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    ctx.fillText(label, pad.left - 8, gy);
  }

  const xTicks = Math.min(6, Math.max(2, maxAge - minAge));
  for (let i = 0; i <= xTicks; i++) {
    const age = Math.round(minAge + (i / xTicks) * (maxAge - minAge));
    const gx = x(age);
    ctx.fillStyle = 'rgba(160,161,170,0.72)';
    ctx.font = '11px Geist Mono';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillText(String(age), gx, height - pad.bottom + 10);
  }

  const gradient = ctx.createLinearGradient(0, pad.top, 0, height - pad.bottom);
  gradient.addColorStop(0, 'rgba(201,74,103,0.18)');
  gradient.addColorStop(1, 'rgba(201,74,103,0)');

  ctx.beginPath();
  ctx.moveTo(x(graphPoints[0].age), height - pad.bottom);
  ctx.lineTo(x(graphPoints[0].age), y(graphPoints[0].pct));
  for (let i = 1; i < graphPoints.length; i++) {
    const prev = graphPoints[i - 1];
    const curr = graphPoints[i];
    const midX = (x(prev.age) + x(curr.age)) / 2;
    ctx.bezierCurveTo(midX, y(prev.pct), midX, y(curr.pct), x(curr.age), y(curr.pct));
  }
  ctx.lineTo(x(graphPoints[graphPoints.length - 1].age), height - pad.bottom);
  ctx.closePath();
  ctx.fillStyle = gradient;
  ctx.fill();

  ctx.beginPath();
  ctx.moveTo(x(graphPoints[0].age), y(graphPoints[0].pct));
  for (let i = 1; i < graphPoints.length; i++) {
    const prev = graphPoints[i - 1];
    const curr = graphPoints[i];
    const midX = (x(prev.age) + x(curr.age)) / 2;
    ctx.bezierCurveTo(midX, y(prev.pct), midX, y(curr.pct), x(curr.age), y(curr.pct));
  }
  ctx.strokeStyle = 'rgba(201,74,103,0.95)';
  ctx.lineWidth = 1.6;
  ctx.stroke();

  ctx.save();
  ctx.translate(14, height / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillStyle = 'rgba(93,95,105,0.95)';
  ctx.font = '10px Geist Mono';
  ctx.textAlign = 'center';
  ctx.fillText('CAGR %', 0, 0);
  ctx.restore();

  ctx.fillStyle = 'rgba(93,95,105,0.95)';
  ctx.font = '10px Geist Mono';
  ctx.textAlign = 'center';
  ctx.fillText('age of death', width / 2, height - 6);
}

window.addEventListener('resize', () => drawChart(), { passive: true });
window.addEventListener('load', () => {
  buildGraphData(12000, 10000000, 30, 65);
  drawChart();
});
</script>
</body>
</html>
